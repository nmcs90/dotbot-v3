{
  "instance_id": null,
  "profile": "kickstart-via-jira",
  "provider": "claude",
  "mcp_enabled": true,
  "standards_as_warp_rules": true,
  "analysis": {
    "auto_approve_splits": false,
    "split_threshold_effort": "XL",
    "question_timeout_hours": null,
    "mode": "on-demand",
    "model": "Opus"
  },
  "execution": {
    "model": "Opus"
  },
  "editor": {
    "name": "off",
    "custom_command": ""
  },
  "costs": {
    "hourly_rate": 50,
    "ai_cost_per_task": 0.50,
    "ai_speedup_factor": 10,
    "currency": "USD"
  },
  "notifications": {
    "enabled": false,
    "server_url": "",
    "api_key": "",
    "channel": "teams",
    "recipients": [],
    "project_name": "",
    "project_description": "",
    "poll_interval_seconds": 30
  },
  "atlassian": {
    "max_pages_to_read": 10
  },
  "azure_devops": {
    "branch_prefix": "initiative"
  },
  "task_categories": ["research", "analysis", "documentation", "implementation", "infrastructure"],
  "kickstart": {
    "dialog": {
      "description": "Claude will research your initiative via Atlassian (Jira + Confluence) and create your mission document and research roadmap.",
      "interview_label": "Research via Atlassian first",
      "interview_hint": "Dotbot will fetch your Jira initiative and Confluence pages for context, then ask clarifying questions if needed",
      "prompt_placeholder": "Paste a Jira initiative key (e.g. PROJ-123) or describe your initiative"
    },
    "preflight": [
      {
        "type": "env_var",
        "name": "Azure DevOps PAT",
        "var": "AZURE_DEVOPS_PAT",
        "message": "Azure DevOps PAT is required for repo operations",
        "hint": "Set AZURE_DEVOPS_PAT in .env.local (PAT needs Code Read/Write + Packaging Read scopes)"
      },
      {
        "type": "env_var",
        "name": "Azure DevOps Org URL",
        "var": "AZURE_DEVOPS_ORG_URL",
        "message": "Azure DevOps organisation URL is required",
        "hint": "Set AZURE_DEVOPS_ORG_URL in .env.local (e.g. https://dev.azure.com/your-org)"
      },
      {
        "type": "env_var",
        "name": "Atlassian Email",
        "var": "ATLASSIAN_EMAIL",
        "message": "Atlassian email is required for downloading Jira/Confluence attachments",
        "hint": "Set ATLASSIAN_EMAIL in .env.local"
      },
      {
        "type": "env_var",
        "name": "Atlassian API Token",
        "var": "ATLASSIAN_API_TOKEN",
        "message": "Atlassian API token is required for downloading Jira/Confluence attachments",
        "hint": "Set ATLASSIAN_API_TOKEN in .env.local (create at https://id.atlassian.com/manage-profile/security/api-tokens)"
      },
      {
        "type": "env_var",
        "name": "Atlassian Cloud ID",
        "var": "ATLASSIAN_CLOUD_ID",
        "message": "Atlassian Cloud ID is required for downloading Jira/Confluence attachments",
        "hint": "Set ATLASSIAN_CLOUD_ID in .env.local (UUID or site URL like https://yoursite.atlassian.net)"
      },
      {
        "type": "mcp_server",
        "name": "atlassian",
        "message": "Atlassian MCP server must be registered",
        "hint": "Run 'claude mcp add atlassian' or 'dotbot init --force' to register it"
      },
      {
        "type": "mcp_server",
        "name": "sourcebot",
        "message": "Sourcebot MCP server is required for repository code search",
        "hint": "Run 'claude mcp add sourcebot' to register the Sourcebot server"
      },
      {
        "type": "mcp_server",
        "name": "dotbot",
        "message": "Dotbot MCP server is required for task management and repo operations",
        "hint": "Run 'dotbot init --force' to re-register it"
      },
      {
        "type": "cli_tool",
        "name": "git",
        "message": "git CLI is required for repository cloning and branch operations",
        "hint": "Install from https://git-scm.com/ or run 'winget install Git.Git'"
      },
      {
        "type": "cli_tool",
        "name": "az",
        "message": "Azure CLI is required for pull request creation",
        "hint": "Install from https://aka.ms/installazurecliwindows or run 'winget install Microsoft.AzureCLI'"
      }
    ],
    "phases": [
      {
        "id": "jira-context",
        "name": "Fetch Jira Context",
        "workflow": "00-kickstart-interview.md",
        "required_outputs": ["briefing/jira-context.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 0 — jira context"
      },
      {
        "id": "product-docs",
        "name": "Generate Product Documents",
        "workflow": "01-plan-product.md",
        "required_outputs": ["mission.md"],
        "front_matter_docs": ["mission.md", "roadmap-overview.md", "research-repos.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 1 — product documents"
      },
      {
        "id": "plan-internet-research",
        "name": "Create Internet Research Task",
        "workflow": "02a-plan-internet-research.md",
        "optional": true,
        "required_outputs_dir": "tasks/todo",
        "min_output_count": 1,
        "commit_paths": ["workspace/tasks/"],
        "commit_message": "chore(kickstart): phase 2a — internet research task created"
      },
      {
        "id": "plan-atlassian-research",
        "name": "Create Atlassian Research Task",
        "workflow": "02b-plan-atlassian-research.md",
        "optional": true,
        "required_outputs_dir": "tasks/todo",
        "min_output_count": 1,
        "commit_paths": ["workspace/tasks/"],
        "commit_message": "chore(kickstart): phase 2b — atlassian research task created"
      },
      {
        "id": "plan-sourcebot-research",
        "name": "Create Sourcebot Research Task",
        "workflow": "02c-plan-sourcebot-research.md",
        "optional": true,
        "required_outputs_dir": "tasks/todo",
        "min_output_count": 1,
        "commit_paths": ["workspace/tasks/"],
        "commit_message": "chore(kickstart): phase 2c — sourcebot research task created"
      },
      {
        "id": "execute-research",
        "name": "Execute Research",
        "type": "workflow",
        "optional": true
      },
      {
        "id": "create-deep-dives",
        "name": "Create Deep-Dive Tasks",
        "workflow": "03-create-deep-dive-tasks.md",
        "required_outputs_dir": "tasks/todo",
        "min_output_count": 1,
        "condition": "file_exists:workspace/product/research-repos.md",
        "commit_paths": ["workspace/tasks/"],
        "commit_message": "chore(kickstart): phase 4 — deep dive tasks created"
      },
      {
        "id": "execute-deep-dives",
        "name": "Execute Deep Dives",
        "type": "workflow",
        "optional": true,
        "condition": "file_exists:workspace/product/research-repos.md"
      },
      {
        "id": "post-research-review",
        "name": "Synthesise Research",
        "type": "llm",
        "workflow": "04-post-research-review.md",
        "required_outputs": ["research-summary.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): post-research review"
      },
      {
        "id": "publish-to-jira",
        "name": "Publish to Jira",
        "workflow": "12-publish-to-jira.md",
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): publish research artifacts to Jira"
      },
      {
        "id": "implementation-research",
        "name": "Research Repositories",
        "type": "llm",
        "workflow": "05-implementation-research.md",
        "condition": "file_exists:workspace/product/research-repos.md",
        "required_outputs": ["briefing/04_IMPLEMENTATION_RESEARCH.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 8 — implementation research"
      },
      {
        "id": "refine-artifacts",
        "name": "Refine Dependencies",
        "type": "llm",
        "workflow": "07-refine-artifacts.md",
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md",
        "required_outputs": ["briefing/05_DEPENDENCY_MAP.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 9 — refine artifacts"
      },
      {
        "id": "plan-implementation",
        "name": "Generate Implementation Plans",
        "type": "llm",
        "workflow": "06-plan-implementation.md",
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md",
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 10 — implementation plans"
      },
      {
        "id": "create-impl-tasks",
        "name": "Create Implementation Tasks",
        "type": "llm",
        "workflow": "09-create-impl-tasks.md",
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md",
        "required_outputs_dir": "tasks/todo",
        "min_output_count": 1,
        "commit_paths": ["workspace/tasks/", "workspace/product/"],
        "commit_message": "chore(kickstart): phase 11 — implementation tasks created"
      },
      {
        "id": "execute-implementation",
        "name": "Execute Implementation",
        "type": "workflow",
        "optional": true,
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md"
      },
      {
        "id": "remediate-builds",
        "name": "Remediate Builds",
        "type": "llm",
        "workflow": "10-remediate-builds.md",
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md",
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 13 — build remediation"
      },
      {
        "id": "draft-handoff",
        "name": "Draft Handoff & PRs",
        "type": "llm",
        "workflow": "11-draft-system-docs.md",
        "condition": "file_exists:workspace/product/briefing/04_IMPLEMENTATION_RESEARCH.md",
        "required_outputs": ["briefing/08_HANDOFF_STATUS.md"],
        "commit_paths": ["workspace/product/"],
        "commit_message": "chore(kickstart): phase 14 — handoff & draft PRs"
      }
    ]
  }
}
